# ═══════════════════���════════════════════════════════════
# Wordsmith — Environment Variables
# Copy to .env.local (frontend) and server/.env (backend)
# ══════════════════════════════════════════════════════���═

# ── Frontend (Vite) — prefix VITE_ to expose to browser ──
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Backend URL (leave empty in dev — Vite proxy handles /api)
# In production, set to your Railway/Render URL
VITE_API_URL=

# ── AI enrichment (NVIDIA NIM — free tier) ───────────────
# Get from: https://build.nvidia.com  → API Key
# Model used: google/gemma-3-27b-it
NVIDIA_API_KEY=your_nvidia_nim_api_key_here

# Comma-separated allowed origins for CORS
# Dev: * (allow all)
# Production: https://your-app.vercel.app
ALLOWED_ORIGINS=*

# ── Seeding only — never use in client code ──────────────
# Get from: Supabase Dashboard → Settings → API → service_role key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
